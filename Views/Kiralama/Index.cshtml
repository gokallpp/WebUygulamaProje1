@model List<Kiralama>

@if(TempData["basarili"] != null)
{
    <div class="alert alert-success">
        @TempData["basarili"]
    </div>
}

<div>
    <div class="row-cols-md-1 pt-3 pb-4">
        <div>
        </div>
        <h1>Kitap Kiralamalar</h1>
    </div>
</div>


<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>OgrenciId</th>
            <th>KitapId</th>

            <th></th>
            <th></th>

        </tr>
    </thead>

    <tbody>
        @foreach (var kiralama in Model)
        {
            <tr>
                <td>@kiralama.Id</td>
                <td>@kiralama.OgrenciId</td>
                <td>@kiralama.Kitap.KitapAdi</td>


                <td><a asp-controller="Kiralama" asp-action="EkleGuncelle" asp-route-id="@kiralama.Id" type="button" style="width:80px" class="btn btn-warning">Güncelle</a> </td>

                <td><a asp-controller="Kiralama" asp-action="Sil" asp-route-id="@kiralama.Id" type="button" style="width:80px" class="btn btn-danger">Sil</a></td>
                
            </tr>
        }
    </tbody>

</table>

<div class="row pt-3 pb-2">
    <div>
        <a asp-controller="Kiralama" asp-action="EkleGuncelle" class="btn btn-lg btn-primary" type="button">Yeni Kiralama Kaydı Oluştur</a>
    </div>
</div>
</div>
